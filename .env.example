# Server
NODE_ENV=development
PORT=3000

# PostgreSQL (required — no defaults in application code)
DATABASE_HOST=127.0.0.1
# Use 56433 (or HYEAMEHA_DB_PORT) when the DB runs in Docker Compose and you connect from the host
DATABASE_PORT=5432
DATABASE_USER=database-user
DATABASE_PASSWORD=your-database-password
DATABASE_NAME=your-database-name

# Redis (referenced by env validation; wire in app when used)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# JWT (required — min 32 chars each)
JWT_ACCESS_SECRET=replace-with-a-long-random-string-at-least-32-chars
JWT_REFRESH_SECRET=replace-with-another-long-random-string-at-least-32-chars
JWT_ACCESS_EXPIRES=7d
JWT_REFRESH_EXPIRES=7d

LOG_LEVEL=info

# Comma-separated CORS origins
CORS_ORIGIN=http://localhost:3000

THROTTLE_AUTH_TTL=60
THROTTLE_AUTH_LIMIT=5
THROTTLE_DEFAULT_TTL=60
THROTTLE_DEFAULT_LIMIT=100

# Docker Compose only — published host ports for DB/Redis (defaults in docker-compose.yml)
# HYEAMEHA_DB_PORT=56433
# HYEAMEHA_REDIS_PORT=56480
